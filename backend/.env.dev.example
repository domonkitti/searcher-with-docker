# app
ADDR=:8080
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# database for local dev / docker compose
DATABASE_URL=postgres://search_user:search_pass@postgres:5432/searchdb?sslmode=disable
POSTGRES_DB=searchdb
POSTGRES_USER=search_user
POSTGRES_PASSWORD=search_pass

# search config
RULES_JSON=/data/rules.json
SYNONYMS_JSON=/data/synonyms.json
ITEMS_XLSX=/data/items.xlsx
KITS_XLSX=/data/kits.xlsx
TITLE_BOOST=3
MIN_SCORE=0.2
NGRAM_MIN=3
NGRAM_MAX=6
REQUEST_TIMEOUT_MS=8000
EMBEDDER_URL=http://embedder:8000
EMBEDDER_TIMEOUT_MS=10000

# optional internal proxy target
NEXT_PROXY_URL=http://web:3000
